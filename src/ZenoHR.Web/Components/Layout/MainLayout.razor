@* REQ-OPS-001: ZenoHR main layout — sidebar navigation + content area. *@
@* REQ-SEC-002: NavMenu is role-aware; sidebar items are absent for unauthorized roles. *@
@inherits LayoutComponentBase

<div class="zenohr-shell">
    <aside class="zenohr-sidebar" role="navigation" aria-label="Main navigation">
        <NavMenu />
    </aside>

    <div class="zenohr-body">
        <header class="zenohr-topbar" role="banner">
            <div class="topbar-breadcrumb"></div>
            <div class="topbar-actions">
                <AuthorizeView>
                    <Authorized>
                        <span class="topbar-role-badge">
                            @context.User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
                        </span>
                    </Authorized>
                </AuthorizeView>
            </div>
        </header>

        <main class="zenohr-content" role="main">
            @Body
        </main>
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">&#x2715;</span>
</div>
