    private sealed record DepartmentItem(string Name, int Count, string Color);
    private sealed record PayrollMonth(string Label, decimal Gross, decimal Net);
    private sealed record EtiMonth(string Label, int Amount);
    private sealed record SalaryBand(string Label, int Count, string Pct, string Color);
    private sealed record LeaveBalance(string Type, string AvgDays, int EmpCount, string Pct, string Color, string MaxDays)
    {
        public string Source => MaxDays.Contains("BCEA") ? "" : "";
    };
