            <div class="score-card @score.CssClass">
                <div class="score-ring-wrap">
                    <svg class="score-ring-svg" width="100" height="100" viewBox="0 0 100 100">
                        <circle class="score-ring-track" cx="50" cy="50" r="40" />
                        <circle class="score-ring-fill @(score.CssClass)-fill" cx="50" cy="50" r="40"
                                stroke-dasharray="251.3" stroke-dashoffset="@dashOffset" />
                    </svg>
                    <div class="score-center">
                        <span class="score-pct @(score.CssClass)-col">@(score.Pct)%</span>
                        <span class="score-label-sm">@score.Label</span>
                    </div>
                </div>
                <div class="score-title">@score.Title</div>
                <div class="score-items">
                    @foreach (var item in score.Items)
                    {
                        <div class="score-item">
                            <div class="score-item-dot @item.DotClass"></div>@item.Text
