                </div>
            </div>
            <div style="margin-top:14px;padding-top:12px;border-top:1px solid var(--border-subtle);">
                <div style="font-size:11.5px;color:var(--text-muted);margin-bottom:10px;">Open alerts by severity</div>
                <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:14px;">
                    <span class="badge badge-danger">1 Sev-1</span>
                    <span class="badge badge-warning">2 Sev-2</span>
                    <span class="badge badge-info">1 Sev-3</span>
                </div>
                <button class="btn btn-primary btn-sm" style="width:100%;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
