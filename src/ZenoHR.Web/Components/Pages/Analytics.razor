                <tr>
                    <td class="tax-label">
                        <span style="display:inline-block;width:8px;height:8px;border-radius:2px;background:#2563eb;margin-right:6px;"></span>ETI
                    </td>
                    <td class="tax-amount" style="color:var(--success);">−R 8,400</td>
                    <td class="tax-pct" style="color:var(--success);">credit</td>
