                <div>
                    <div style="font-size:11px;text-transform:uppercase;letter-spacing:.05em;color:var(--text-muted);font-weight:600;margin-bottom:2px;">YTD Cost</div>
                    <div style="font-family:var(--font-mono);font-size:14px;font-weight:700;color:var(--text-primary);">R 33.8M</div>
                </div>
            </div>
        </div>

        <!-- REQ-OPS-006: Tax Breakdown -->
        <div class="card">
            <div class="card-header">
                <span class="card-title">Tax Breakdown</span>
                <span class="badge badge-muted badge-nodot">Feb 2026</span>
            </div>
            <div class="doughnut-wrap" style="height:140px;display:flex;align-items:center;justify-content:center;">
                <svg width="120" height="120" viewBox="0 0 120 120">
                    <!-- PAYE 81% -->
                    <circle cx="60" cy="60" r="45" fill="none" stroke="#1d4777" stroke-width="16"
                            stroke-dasharray="@((2 * Math.PI * 45 * 0.81).ToString("F1")) @((2 * Math.PI * 45).ToString("F1"))"
                            stroke-dashoffset="@((2 * Math.PI * 45).ToString("F1"))"
                            transform="rotate(-90 60 60)" />
                    <!-- UIF 9% -->
                    <circle cx="60" cy="60" r="45" fill="none" stroke="#d4890e" stroke-width="16"
                            stroke-dasharray="@((2 * Math.PI * 45 * 0.09).ToString("F1")) @((2 * Math.PI * 45).ToString("F1"))"
                            stroke-dashoffset="@((2 * Math.PI * 45 * (1 - 0.81)).ToString("F1"))"
                            transform="rotate(-90 60 60)" />
                    <!-- SDL 10% -->
                    <circle cx="60" cy="60" r="45" fill="none" stroke="#16a34a" stroke-width="16"
                            stroke-dasharray="@((2 * Math.PI * 45 * 0.10).ToString("F1")) @((2 * Math.PI * 45).ToString("F1"))"
                            stroke-dashoffset="@((2 * Math.PI * 45 * (1 - 0.81 - 0.09)).ToString("F1"))"
                            transform="rotate(-90 60 60)" />
                </svg>
                <div class="doughnut-center">
                    <div class="doughnut-center-value" style="font-size:1.1rem;">R 302K</div>
                    <div class="doughnut-center-label">Total Tax</div>
