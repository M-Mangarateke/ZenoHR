                        <div class="compliance-trend-bar" style="background:#16a34a;opacity:@(month.Bcea / 100.0);flex:@month.Bcea;"></div>
                        <div class="compliance-trend-bar" style="background:#d4890e;opacity:@(month.Popia / 100.0);flex:@month.Popia;"></div>
                    </div>
                </div>
            }
            <div style="display:flex;gap:16px;margin-top:12px;flex-wrap:wrap;">
                <div style="display:flex;align-items:center;gap:6px;font-size:12px;color:var(--text-secondary);">
                    <div style="width:20px;height:2px;background:#1d4777;border-radius:2px;"></div> SARS
                </div>
                <div style="display:flex;align-items:center;gap:6px;font-size:12px;color:var(--text-secondary);">
                    <div style="width:20px;height:2px;background:#16a34a;border-radius:2px;"></div> BCEA
                </div>
                <div style="display:flex;align-items:center;gap:6px;font-size:12px;color:var(--text-secondary);">
                    <div style="width:20px;height:2px;background:#d4890e;border-radius:2px;"></div> POPIA
                </div>
            </div>
        </div>

        <!-- REQ-OPS-006: Risk Exposure -->
        <div class="card">
            <div class="card-header">
                <span class="card-title">Risk Exposure</span>
                <span class="badge badge-danger">R 125,000</span>
            </div>
            <!-- Risk bar visualization -->
            <div style="padding:16px 0;">
                <div style="display:flex;gap:4px;height:80px;align-items:flex-end;">
                    <div style="flex:1;background:var(--danger);border-radius:4px 4px 0 0;height:80%;"></div>
                    <div style="flex:1;background:var(--warning);border-radius:4px 4px 0 0;height:50%;"></div>
