            </table>
        </div>

        <!-- REQ-OPS-006: ETI Incentive -->
        <div class="card">
            <div class="card-header">
                <span class="card-title">ETI Incentive</span>
            </div>
            <div style="margin-bottom:12px;">
                <div class="kpi-value" style="font-size:22px;color:var(--success);">R 8,400</div>
                <div class="kpi-meta" style="margin-top:4px;">
                    <span style="font-weight:600;color:var(--success);">12 eligible</span> employees this month
