</AuthorizeView>

<!-- ── Section 4: Leave Intelligence ──────────────── -->
<div class="grid grid-cols-60-40 gap-4 mb-6">

    <!-- Leave Analysis (tabbed) -->
    <div class="card">
        <div class="card-header">
            <span class="card-title">Leave Analysis</span>
        </div>
        <!-- REQ-OPS-006: Leave sub-tabs -->
        <div class="leave-tabs">
            <button class="leave-tab @(_activeLeaveTab == "balance" ? "active" : "")"
                    @onclick='() => _activeLeaveTab = "balance"'>Balance Summary</button>
            <button class="leave-tab @(_activeLeaveTab == "upcoming" ? "active" : "")"
                    @onclick='() => _activeLeaveTab = "upcoming"'>Upcoming (30d)</button>
        </div>

        @if (_activeLeaveTab == "balance")
        {
            <!-- Tab: Balance Summary -->
            @foreach (var leave in _leaveBalances)
            {
                <div class="leave-row">
                    <div class="leave-row-header">
                        <span class="leave-type-name">@leave.Type</span>
                        <span class="leave-type-meta">Avg <strong>@leave.AvgDays</strong> available · @leave.EmpCount employees</span>
                    </div>
                    <div class="progress progress-md">
                        <div class="progress-fill" style="width:@leave.Pct;background:@leave.Color;"></div>
                    </div>
                    <div class="leave-progress-label"><span>0 days</span><span>@leave.MaxDays (@leave.Source)</span></div>
                </div>
            }
        }
        else if (_activeLeaveTab == "upcoming")
        {
            <!-- Tab: Upcoming -->
            @foreach (var item in _upcomingLeave)
            {
                <div class="upcoming-item">
                    <div class="avatar avatar-sm" style="background:@item.AvatarBg;color:@item.AvatarColor;">@item.Initials</div>
                    <div class="upcoming-info">
                        <div class="upcoming-name">@item.Name</div>
                        <div class="upcoming-detail">@item.Detail</div>
                    </div>
                    <span class="badge @item.BadgeClass">@item.Status</span>
                </div>
            }
        }
    </div>

    <!-- Leave Heatmap by Department -->
    <div class="card">
        <div class="card-header">
            <span class="card-title">By Department</span>
            <span class="badge badge-muted badge-nodot">Avg days remaining</span>
        </div>
        <table class="heatmap-table">
            <thead>
                <tr>
                    <th>Department</th>
                    <th style="text-align:center;">Annual</th>
                    <th style="text-align:center;">Sick</th>
                    <th style="text-align:center;">Pending</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in _leaveHeatmap)
                {
                    <tr>
                        <td style="font-size:12px;font-weight:600;color:var(--text-primary);">@row.Dept</td>
                        <td><div class="heatmap-cell @row.AnnualClass">@row.Annual</div></td>
                        <td><div class="heatmap-cell @row.SickClass">@row.Sick</div></td>
                        <td><div class="heatmap-cell @row.PendingClass">@row.Pending</div></td>
                    </tr>
                }
            </tbody>
        </table>
        <div style="margin-top:14px;padding-top:12px;border-top:1px solid var(--border-subtle);">
            <div style="font-size:11px;color:var(--text-muted);font-weight:600;text-transform:uppercase;letter-spacing:.05em;margin-bottom:8px;">Legend</div>
            <div style="display:flex;gap:12px;flex-wrap:wrap;">
                <div style="display:flex;align-items:center;gap:5px;font-size:11.5px;color:var(--text-secondary);">
                    <div style="width:10px;height:10px;border-radius:3px;background:var(--success-subtle);"></div> &gt;15d safe
                </div>
                <div style="display:flex;align-items:center;gap:5px;font-size:11.5px;color:var(--text-secondary);">
                    <div style="width:10px;height:10px;border-radius:3px;background:var(--warning-subtle);"></div> 7-15d watch
                </div>
                <div style="display:flex;align-items:center;gap:5px;font-size:11.5px;color:var(--text-secondary);">
                    <div style="width:10px;height:10px;border-radius:3px;background:rgba(220,38,38,0.08);"></div> &lt;7d risk
                </div>
            </div>
        </div>
    </div>

</div>

<!-- ── Section 5: Compliance Scorecard (Director/HRMgr only) ── -->
<AuthorizeView Roles="Director,HRManager">
    <div class="mb-2"
         style="font-size:11px;text-transform:uppercase;letter-spacing:.08em;color:var(--text-muted);font-weight:700;margin-bottom:8px;">
        Compliance &amp; Risk
        <span class="badge badge-muted badge-nodot"
              style="margin-left:8px;font-size:10px;text-transform:none;letter-spacing:0;">Director &amp; HR Manager only</span>
    </div>

    <!-- REQ-OPS-006: Compliance Score Rings Row -->
    <div class="score-grid3 mb-4">
        @foreach (var score in _complianceScores)
        {
