            <div style="font-size:11px;color:var(--text-muted);margin-top:8px;text-align:center;">
                Employment Tax Incentive (ETI) — last 6 months
            </div>
        </div>

    </div>

    <!-- REQ-OPS-006: Salary Band Distribution -->
    <div class="grid grid-cols-60-40 gap-4 mb-6">
        <div class="card">
            <div class="card-header">
                <span class="card-title">Salary Band Distribution</span>
                <span class="badge badge-muted badge-nodot">Monthly gross</span>
