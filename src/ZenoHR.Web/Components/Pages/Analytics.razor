                    </td>
                    <td class="tax-amount">R 245,100</td>
                    <td class="tax-pct">81%</td>
                </tr>
                <tr>
                    <td class="tax-label">
                        <span style="display:inline-block;width:8px;height:8px;border-radius:2px;background:#d4890e;margin-right:6px;"></span>UIF
                    </td>
                    <td class="tax-amount">R 28,200</td>
                    <td class="tax-pct">9%</td>
                </tr>
                <tr>
                    <td class="tax-label">
                        <span style="display:inline-block;width:8px;height:8px;border-radius:2px;background:#16a34a;margin-right:6px;"></span>SDL
                    </td>
                    <td class="tax-amount">R 28,500</td>
                    <td class="tax-pct">9%</td>
