    // REQ-OPS-001: Wizard navigation
    private void OpenOnboardingWizard()
    {
        _showOnboardingWizard = true;
        _wizardStep = 1;
        _provisioningStarted = false;
        _provisioningDone = false;
        _provisionPercent = 0;
    }

    private void CloseOnboardingWizard()
    {
        _showOnboardingWizard = false;
    }

    private void SetWizardStep(int step)
    {
        _wizardStep = step;
    }

    private void WizardNext()
    {
        if (_wizardStep < 5) _wizardStep++;
    }

    private void WizardBack()
    {
        if (_wizardStep > 1) _wizardStep--;
    }

    // REQ-OPS-001: Simulated provisioning flow (UI only — no backend wiring)
    private async Task StartProvisioning()
    {
        _provisioningStarted = true;
        var steps = new (int Pct, string Msg)[]
        {
            (20, "Creating company_settings document..."),
            (40, "Seeding 5 statutory rule sets..."),
            (60, "Creating user_role_assignments..."),
            (80, "Configuring Firestore security rules..."),
            (95, "Sending welcome email..."),
            (100, "Done!")
        };

        foreach (var (pct, msg) in steps)
        {
            _provisionPercent = pct;
            _provisionStatus = msg;
            StateHasChanged();
            await Task.Delay(700);
        }

        _provisioningDone = true;
        StateHasChanged();
    }

