@* REQ-HR-001, REQ-SEC-002, PRD-15 S10: Settings — Director and HRManager only. *@
@* Five admin tabs: Users, Departments, Company, Security, Data Archival. *@
@* Manager and Employee: None — route blocked, nav item absent. *@
@page "/settings"
@attribute [Authorize(Roles = "Director,HRManager")]
@using Microsoft.AspNetCore.Authorization
@inject NavigationManager Nav

<PageTitle>Settings — ZenoHR</PageTitle>

@* Redirect /settings to /settings/users (default tab) *@

@code {
    // REQ-HR-001
    protected override void OnInitialized()
    {
        Nav.NavigateTo("/settings/users", replace: true);
    }
}
