@* REQ-HR-001, REQ-SEC-002: Dashboard — all authenticated tenant users. Widget rendering is role-conditional per PRD-15 Section 6. *@
@* REQ-COMP-001: Compliance score widget visible to Director/HRManager only. *@
@page "/dashboard"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@inject IJSRuntime JS
@inject NavigationManager Nav

<PageTitle>Dashboard — ZenoHR</PageTitle>

<style>
    /* KPI icon colors */
    .kpi-icon-blue {
        background: var(--brand-primary-subtle);
        color: var(--brand-primary);
    }
    .kpi-icon-orange {
        background: var(--brand-accent-subtle);
        color: var(--brand-accent);
    }
    .kpi-icon-green {
        background: var(--success-subtle);
        color: var(--success);
    }
    .kpi-icon-amber {
        background: var(--warning-subtle);
        color: var(--warning);
    }
    /* Dark card text overrides */
    .card-dark .kpi-label { color: rgba(203, 213, 225, 0.6); }
    .card-dark .kpi-value { color: white; }
    .card-dark .kpi-meta  { color: rgba(203, 213, 225, 0.5); }
    /* EMP201 dark card accent border */
    .card-emp201 { border-left: 3px solid var(--brand-accent); }
    /* Chart container */
    .chart-container { position: relative; height: 180px; }
    /* Activity row */
    .activity-row {
        display: flex;
        align-items: center;
        gap: var(--space-3);
        padding: 10px 0;
        border-bottom: 1px solid var(--border-subtle);
    }
    .activity-row:last-child { border-bottom: none; }
    .activity-desc { flex: 1; font-size: 13px; color: var(--text-primary); font-weight: 500; }
    .activity-sub  { font-size: 11.5px; color: var(--text-secondary); margin-top: 1px; }
    /* Mobile responsive */
    @@media (max-width: 768px) { .grid-cols-4 { grid-template-columns: 1fr 1fr; } }
    @@media (max-width: 640px) {
        .grid-cols-4 { grid-template-columns: 1fr; }
        .page-greeting { font-size: clamp(20px, 5vw, 28px); }
        .kpi-value { font-size: clamp(20px, 5vw, 28px); }
        .chart-container { height: 160px; }
    }
</style>

@* ── Loading indicator ─────────────────────────────────────────────────── *@
@if (_loading)
{
    <div style="display:flex;align-items:center;justify-content:center;padding:var(--space-8);gap:var(--space-3);" role="status" aria-label="Loading dashboard data">
        <svg width="24" height="24" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" style="animation:spin 1s linear infinite;" aria-hidden="true">
            <style>@@keyframes spin { to { transform: rotate(360deg); } }</style>
            <circle cx="12" cy="12" r="10" stroke="var(--border-subtle)" stroke-width="3" fill="none" />
            <path d="M12 2a10 10 0 0 1 10 10" stroke="var(--brand-primary)" stroke-width="3" fill="none" stroke-linecap="round" />
        </svg>
        <span style="font-size:14px;color:var(--text-secondary);">Loading dashboard...</span>
    </div>
}

@* ── Director / HRManager view ──────────────────────────────────────────── *@
<AuthorizeView Roles="Director,HRManager">
    <Authorized>
        <!-- Page header -->
        <div class="page-header">
            <div class="flex items-center justify-between">
                <div>
                    <h1 class="page-greeting">Good morning, <span>Sarah</span></h1>
                    @* TODO: wire greeting name to current user's display name *@
                    <p class="page-subtitle">Here's what's happening at Zenowethu today, @DateTime.Now.ToString("dddd d MMMM yyyy")</p>
                </div>
                <div class="flex gap-3">
                    <button class="btn btn-secondary btn-sm" aria-label="Export dashboard data">
                        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                            <polyline points="7 10 12 15 17 10" />
                            <line x1="12" x2="12" y1="15" y2="3" />
                        </svg>
                        Export
                    </button>
                    <button class="btn btn-primary btn-sm" @onclick='() => Nav.NavigateTo("/payroll/new")' aria-label="Create new payroll run">
                        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="12" x2="12" y1="5" y2="19" />
                            <line x1="5" x2="19" y1="12" y2="12" />
                        </svg>
                        New Payroll Run
                    </button>
                </div>
            </div>
        </div>

        <!-- KPI Row — all 4 cards for Director/HRManager (REQ-HR-001, REQ-COMP-001) -->
        <div class="grid grid-cols-4 gap-4 mb-6">

            <!-- Total Employees -->
            <div class="card kpi-card">
                <div class="flex items-center justify-between mb-3">
                    <span class="kpi-label">Total Employees</span>
                    <div class="kpi-icon kpi-icon-blue"
                         style="width:32px;height:32px;border-radius:var(--radius-md);display:flex;align-items:center;justify-content:center;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
                            <circle cx="9" cy="7" r="4" />
                            <path d="M22 21v-2a4 4 0 0 0-3-3.87" />
                            <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                        </svg>
                    </div>
                </div>
                @* TODO: wire to EmployeeService.GetHeadcountAsync() *@
                <div class="kpi-value">247</div>
                <div class="kpi-meta">
                    <span class="trend-up">
                        <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2.5">
                            <polyline points="18 15 12 9 6 15" />
                        </svg>
                        +3
                    </span>
                    new this month
                </div>
            </div>

            <!-- Monthly Payroll -->
            <div class="card kpi-card">
                <div class="flex items-center justify-between mb-3">
                    <span class="kpi-label">Monthly Payroll</span>
                    <div class="kpi-icon kpi-icon-orange"
                         style="width:32px;height:32px;border-radius:var(--radius-md);display:flex;align-items:center;justify-content:center;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="12" x2="12" y1="1" y2="23" />
                            <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
                        </svg>
                    </div>
                </div>
                @* TODO: wire to PayrollService.GetCurrentMonthTotalAsync() — MoneyZAR *@
                @{
                    decimal payrollTotal = 2_847_320.00m;
                }
                <div class="kpi-value" style="font-size:22px; letter-spacing:-1px;">
                    R @payrollTotal.ToString("N0")<span style="font-size:16px;">.00</span>
                </div>
                <div class="kpi-meta">
                    <span class="trend-up">
                        <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2.5">
                            <polyline points="18 15 12 9 6 15" />
                        </svg>
                        2.1%
                    </span>
                    vs Jan 2026
                </div>
            </div>

            <!-- Compliance Score -->
            <div class="card kpi-card">
                <div class="flex items-center justify-between mb-3">
                    <span class="kpi-label">Compliance Score</span>
                    <div class="kpi-icon kpi-icon-green"
                         style="width:32px;height:32px;border-radius:var(--radius-md);display:flex;align-items:center;justify-content:center;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                        </svg>
                    </div>
                </div>
                @* TODO: wire to ComplianceService.GetScoreAsync() — REQ-COMP-001 *@
                <div class="kpi-value" style="color: var(--success);">94%</div>
                <div class="kpi-meta">
                    <span style="color:var(--warning);font-weight:600;font-size:11.5px;">3 items</span> need attention
                </div>
            </div>

            <!-- Leave Requests -->
            <div class="card kpi-card">
                <div class="flex items-center justify-between mb-3">
                    <span class="kpi-label">Leave Requests</span>
                    <div class="kpi-icon kpi-icon-amber"
                         style="width:32px;height:32px;border-radius:var(--radius-md);display:flex;align-items:center;justify-content:center;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <rect width="18" height="18" x="3" y="4" rx="2" ry="2" />
                            <line x1="16" x2="16" y1="2" y2="6" />
                            <line x1="8" x2="8" y1="2" y2="6" />
                            <line x1="3" x2="21" y1="10" y2="10" />
                        </svg>
                    </div>
                </div>
                @* TODO: wire to LeaveService.GetPendingCountAsync() — REQ-HR-002 *@
                <div class="kpi-value" style="color: var(--brand-accent);">8</div>
                <div class="kpi-meta">
                    <span style="color:var(--brand-accent);font-weight:600;font-size:11.5px;">5 pending</span> your approval
                </div>
            </div>

        </div><!-- /KPI Row -->

        <!-- Row 2: Payroll Trend Chart + Upcoming Deadlines -->
        <div class="grid grid-cols-60-40 gap-4 mb-6">

            <!-- Payroll Trend Chart -->
            <div class="card">
                <div class="card-header">
                    <span class="card-title">Payroll Cost Trend</span>
                    <div class="flex gap-2 items-center">
                        <span class="badge badge-muted badge-nodot">Sep–Feb 2026</span>
                        <a class="card-action" href="/payroll">View runs &rarr;</a>
                    </div>
                </div>
                <div class="chart-container">
                    <canvas id="payrollChart"></canvas>
                </div>
            </div>

            <!-- Upcoming Deadlines -->
            <div class="card">
                <div class="card-header">
                    <span class="card-title">Upcoming Deadlines</span>
                    <a class="card-action" href="/compliance">All &rarr;</a>
                </div>
                @* TODO: wire deadline list to ComplianceService.GetUpcomingDeadlinesAsync() — REQ-COMP-002 *@
                <div class="deadline-list">
                    <div class="deadline-item">
                        <div class="deadline-dot" style="background: var(--danger);"></div>
                        <div class="deadline-info">
                            <div class="deadline-name">EMP201: February 2026</div>
                            <div class="deadline-date">Due 7 March 2026 &nbsp;&middot;&nbsp; <span style="color:var(--danger);font-weight:600;">7 days</span></div>
                        </div>
                        <span class="badge badge-danger">Urgent</span>
                    </div>
                    <div class="deadline-item">
                        <div class="deadline-dot" style="background: var(--warning);"></div>
                        <div class="deadline-info">
                            <div class="deadline-name">EMP501 Interim Filing</div>
                            <div class="deadline-date">Due 31 Oct 2026 &nbsp;&middot;&nbsp; <span style="color:var(--warning);font-weight:600;">253 days</span></div>
                        </div>
                        <span class="badge badge-warning">Upcoming</span>
                    </div>
                    <div class="deadline-item">
                        <div class="deadline-dot" style="background: var(--info);"></div>
                        <div class="deadline-info">
                            <div class="deadline-name">Leave Cycle Reset</div>
                            <div class="deadline-date">1 March 2026 &nbsp;&middot;&nbsp; <span style="color:var(--info);font-weight:600;">10 days</span></div>
                        </div>
                        <span class="badge badge-info">Info</span>
                    </div>
                    <div class="deadline-item">
                        <div class="deadline-dot" style="background: var(--success);"></div>
                        <div class="deadline-info">
                            <div class="deadline-name">IRP5 / IT3(a) Issue</div>
                            <div class="deadline-date">Due May 2026 &nbsp;&middot;&nbsp; <span style="color:var(--success);font-weight:600;">On track</span></div>
                        </div>
                        <span class="badge badge-success">On Track</span>
                    </div>
                </div>

                <!-- EMP201 dark action card (REQ-COMP-002) -->
                <div class="card card-dark card-emp201" style="margin-top: var(--space-4); padding: 16px 18px;">
                    <div class="flex items-center gap-3">
                        <div style="width:36px;height:36px;border-radius:var(--radius-md);background:rgba(212,137,14,0.2);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                                 stroke="#d4890e" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                <path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z" />
                                <path d="M12 9v4" />
                                <path d="M12 17h.01" />
                            </svg>
                        </div>
                        <div style="flex:1;">
                            <div style="font-size:13px;font-weight:600;color:white;line-height:1.3;">EMP201 due in 7 days</div>
                            @* TODO: wire to ComplianceService — MoneyZAR for amount *@
                            <div style="font-size:11.5px;color:rgba(203,213,225,0.6);margin-top:2px;">Feb 2026 &bull; R 2,847,320.00 payroll</div>
                        </div>
                        <button class="btn btn-accent btn-sm">Generate</button>
                    </div>
                </div>
            </div>

        </div><!-- /Row 2 -->

        <!-- Row 3: Recent Activity Table (REQ-HR-001, audit trail preview) -->
        <div class="card">
            <div class="card-header">
                <span class="card-title">Recent Activity</span>
                <a class="card-action" href="/audit">Audit trail &rarr;</a>
            </div>
            @* TODO: wire to AuditService.GetRecentEventsAsync(limit: 5) — REQ-HR-001 *@
            <div class="table-wrapper">
                <table>
                    <thead>
                        <tr>
                            <th>Time</th>
                            <th>Action</th>
                            <th>User</th>
                            <th>Reference</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="td-mono td-muted">09:14</td>
                            <td>
                                <div class="person-cell">
                                    <div class="avatar avatar-sm" style="background:var(--brand-primary-subtle);color:var(--brand-primary);">SN</div>
                                    <div>
                                        <div style="font-size:13px;font-weight:500;">Payroll Run Approved</div>
                                        <div class="td-muted">Feb 2026: Monthly Run</div>
                                    </div>
                                </div>
                            </td>
                            <td class="td-muted">Sarah Nkosi</td>
                            <td class="td-mono td-muted">RUN-2026-02</td>
                            <td><span class="badge badge-success">Approved</span></td>
                        </tr>
                        <tr>
                            <td class="td-mono td-muted">08:47</td>
                            <td>
                                <div class="person-cell">
                                    <div class="avatar avatar-sm" style="background:var(--warning-subtle);color:var(--warning);">TM</div>
                                    <div>
                                        <div style="font-size:13px;font-weight:500;">Leave Request Submitted</div>
                                        <div class="td-muted">Annual Leave &middot; 5 days</div>
                                    </div>
                                </div>
                            </td>
                            <td class="td-muted">Thabo Molefe</td>
                            <td class="td-mono td-muted">LVE-2026-0089</td>
                            <td><span class="badge badge-warning">Pending</span></td>
                        </tr>
                        <tr>
                            <td class="td-mono td-muted">08:22</td>
                            <td>
                                <div class="person-cell">
                                    <div class="avatar avatar-sm" style="background:var(--info-subtle);color:var(--info);">KD</div>
                                    <div>
                                        <div style="font-size:13px;font-weight:500;">Employee Onboarded</div>
                                        <div class="td-muted">Junior Developer &middot; IT Dept</div>
                                    </div>
                                </div>
                            </td>
                            <td class="td-muted">Kobus de Bruyn</td>
                            <td class="td-mono td-muted">EMP-0247</td>
                            <td><span class="badge badge-primary">Active</span></td>
                        </tr>
                        <tr>
                            <td class="td-mono td-muted">07:55</td>
                            <td>
                                <div class="person-cell">
                                    <div class="avatar avatar-sm" style="background:var(--success-subtle);color:var(--success);">SN</div>
                                    <div>
                                        <div style="font-size:13px;font-weight:500;">EMP201 Jan 2026 Submitted</div>
                                        <div class="td-muted">SARS e@syFile &middot; R 2,798,100</div>
                                    </div>
                                </div>
                            </td>
                            <td class="td-muted">Sarah Nkosi</td>
                            <td class="td-mono td-muted">EMP201-01-26</td>
                            <td><span class="badge badge-success">Filed</span></td>
                        </tr>
                        <tr>
                            <td class="td-mono td-muted">07:30</td>
                            <td>
                                <div class="person-cell">
                                    <div class="avatar avatar-sm" style="background:var(--brand-accent-subtle);color:var(--brand-accent);">NZ</div>
                                    <div>
                                        <div style="font-size:13px;font-weight:500;">Timesheet Approved</div>
                                        <div class="td-muted">Week 7 &middot; Operations Dept</div>
                                    </div>
                                </div>
                            </td>
                            <td class="td-muted">Nandi Zulu</td>
                            <td class="td-mono td-muted">TS-2026-W07</td>
                            <td><span class="badge badge-success">Approved</span></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </Authorized>
</AuthorizeView>

@* ── Manager view ───────────────────────────────────────────────────────── *@
<AuthorizeView Roles="Manager">
    <Authorized>
        <!-- Page header (Manager) -->
        <div class="page-header">
            <div class="flex items-center justify-between">
                <div>
                    <h1 class="page-greeting">Good morning</h1>
                    <p class="page-subtitle">Your team overview for @DateTime.Now.ToString("dddd d MMMM yyyy")</p>
                </div>
            </div>
        </div>

        <!-- Manager KPI cards: team headcount + pending approvals (PRD-15) -->
        <div class="grid grid-cols-4 gap-4 mb-6">
            <div class="card kpi-card">
                <div class="flex items-center justify-between mb-3">
                    <span class="kpi-label">Team Headcount</span>
                    <div class="kpi-icon kpi-icon-blue"
                         style="width:32px;height:32px;border-radius:var(--radius-md);display:flex;align-items:center;justify-content:center;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
                            <circle cx="9" cy="7" r="4" />
                            <path d="M22 21v-2a4 4 0 0 0-3-3.87" />
                            <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                        </svg>
                    </div>
                </div>
                @* TODO: wire to EmployeeService.GetDeptHeadcountAsync(deptId) *@
                <div class="kpi-value">12</div>
                <div class="kpi-meta">Your department</div>
            </div>

            <div class="card kpi-card">
                <div class="flex items-center justify-between mb-3">
                    <span class="kpi-label">Pending Approvals</span>
                    <div class="kpi-icon kpi-icon-amber"
                         style="width:32px;height:32px;border-radius:var(--radius-md);display:flex;align-items:center;justify-content:center;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <rect width="18" height="18" x="3" y="4" rx="2" ry="2" />
                            <line x1="16" x2="16" y1="2" y2="6" />
                            <line x1="8" x2="8" y1="2" y2="6" />
                            <line x1="3" x2="21" y1="10" y2="10" />
                        </svg>
                    </div>
                </div>
                @* TODO: wire to LeaveService.GetPendingTeamApprovalsAsync(managerId) *@
                <div class="kpi-value" style="color: var(--brand-accent);">3</div>
                <div class="kpi-meta"><span style="color:var(--brand-accent);font-weight:600;font-size:11.5px;">3 pending</span> your approval</div>
            </div>

            <!-- Self-access guarantee: own leave balance + next payslip (PRD-15 §1.6) -->
            <div class="card kpi-card">
                <div class="flex items-center justify-between mb-3">
                    <span class="kpi-label">My Leave Balance</span>
                    <div class="kpi-icon kpi-icon-green"
                         style="width:32px;height:32px;border-radius:var(--radius-md);display:flex;align-items:center;justify-content:center;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                        </svg>
                    </div>
                </div>
                @* TODO: wire to LeaveService.GetBalanceAsync(currentUserId) — REQ-HR-002 *@
                <div class="kpi-value">15</div>
                <div class="kpi-meta">days annual leave remaining</div>
            </div>

            <div class="card kpi-card">
                <div class="flex items-center justify-between mb-3">
                    <span class="kpi-label">Next Payslip</span>
                    <div class="kpi-icon kpi-icon-orange"
                         style="width:32px;height:32px;border-radius:var(--radius-md);display:flex;align-items:center;justify-content:center;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="12" x2="12" y1="1" y2="23" />
                            <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
                        </svg>
                    </div>
                </div>
                @* TODO: wire to PayrollService.GetNextPayslipDateAsync(currentUserId) *@
                <div class="kpi-value" style="font-size:18px;">28 Feb 2026</div>
                <div class="kpi-meta">monthly pay date</div>
            </div>
        </div>
    </Authorized>
</AuthorizeView>

@* ── Employee view (self-access guarantee — PRD-15 §1.6) ────────────────── *@
<AuthorizeView Roles="Employee">
    <Authorized>
        <!-- Page header (Employee) -->
        <div class="page-header">
            <div class="flex items-center justify-between">
                <div>
                    <h1 class="page-greeting">Good morning</h1>
                    <p class="page-subtitle">Your personal overview for @DateTime.Now.ToString("dddd d MMMM yyyy")</p>
                </div>
            </div>
        </div>

        <!-- Employee self-access: own leave balance + next payslip date (PRD-15 §1.6, REQ-HR-002) -->
        <div class="grid grid-cols-4 gap-4 mb-6">
            <div class="card kpi-card">
                <div class="flex items-center justify-between mb-3">
                    <span class="kpi-label">My Leave Balance</span>
                    <div class="kpi-icon kpi-icon-green"
                         style="width:32px;height:32px;border-radius:var(--radius-md);display:flex;align-items:center;justify-content:center;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <rect width="18" height="18" x="3" y="4" rx="2" ry="2" />
                            <line x1="16" x2="16" y1="2" y2="6" />
                            <line x1="8" x2="8" y1="2" y2="6" />
                            <line x1="3" x2="21" y1="10" y2="10" />
                        </svg>
                    </div>
                </div>
                @* TODO: wire to LeaveService.GetBalanceAsync(currentUserId) *@
                <div class="kpi-value">15</div>
                <div class="kpi-meta">days annual leave remaining</div>
            </div>

            <div class="card kpi-card">
                <div class="flex items-center justify-between mb-3">
                    <span class="kpi-label">Next Payslip</span>
                    <div class="kpi-icon kpi-icon-orange"
                         style="width:32px;height:32px;border-radius:var(--radius-md);display:flex;align-items:center;justify-content:center;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="12" x2="12" y1="1" y2="23" />
                            <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
                        </svg>
                    </div>
                </div>
                @* TODO: wire to PayrollService.GetNextPayslipDateAsync(currentUserId) *@
                <div class="kpi-value" style="font-size:18px;">28 Feb 2026</div>
                <div class="kpi-meta">monthly pay date</div>
            </div>
        </div>
    </Authorized>
</AuthorizeView>

@code {
    // REQ-HR-001, REQ-SEC-002
    private bool _isDark;
    private bool _rendered;
    private bool _loading = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var theme = await JS.InvokeAsync<string>("zenohr.initTheme");
                _isDark = theme == "dark";
                await JS.InvokeVoidAsync("zenohr.initLucide");
                await JS.InvokeVoidAsync("zenohr.renderPayrollChart",
                    "payrollChart",
                    new[] { "Sep", "Oct", "Nov", "Dec", "Jan", "Feb" },
                    new[] { 2640000, 2710000, 2680000, 2920000, 2798100, 2847320 },
                    _isDark);
                _rendered = true;
                _loading = false;
                StateHasChanged();
            }
            catch (JSDisconnectedException)
            {
                // Circuit disconnected — safe to ignore during prerender/disconnect.
            }
        }
    }
}
