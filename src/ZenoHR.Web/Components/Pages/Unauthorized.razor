@* REQ-SEC-003: Shown when an authenticated user navigates to a route their role cannot access. *@
@* Navigation items for the forbidden route are NOT shown in NavMenu (absent, not disabled). *@
@* PRD-15 Section 10: "All unauthorized route access redirects to /unauthorized (not /login)." *@
@page "/unauthorized"
@attribute [AllowAnonymous]

<PageTitle>Access Denied — ZenoHR</PageTitle>

<div class="unauthorized-shell">
    <div class="unauthorized-card">
        <div class="unauthorized-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24"
                 fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
                 stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/>
            </svg>
        </div>
        <h1>Access Denied</h1>
        <p>
            You don't have permission to view this page.
            If you believe this is an error, contact your system administrator.
        </p>
        <div class="unauthorized-actions">
            <a href="/dashboard" class="btn btn-primary">Go to Dashboard</a>
        </div>
    </div>
</div>
