    // Actor display helpers — REQ-COMP-004
    private static string GetActorDisplayName(string actor)
    {
        if (actor.StartsWith("system@")) return "System";
        var local = actor.Split('@')[0];
        var parts = local.Split('.');
        if (parts.Length >= 2)
            return char.ToUpper(parts[0][0]) + parts[0][1..] + " " + char.ToUpper(parts[1][0]) + parts[1][1..];
        return local;
    }

    private static string GetActorInitials(string actor)
    {
        if (actor.StartsWith("system@")) return "SYS";
        var name = GetActorDisplayName(actor);
        var parts = name.Split(' ');
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[1][0]}"
            : name[..Math.Min(2, name.Length)].ToUpper();
    }

    private static string GetActorAvatarClass(string actor) => actor.StartsWith("system@") ? "" : "av-7";

    private static string GetActorRole(string actor)
    {
        if (actor.StartsWith("system@")) return "Scheduler";
        if (actor.Contains("sarah")) return "HR Manager";
        if (actor.Contains("thabo")) return "Operations Manager";
        return "Staff";
    }

    private static string CapitalizeFirst(string s) =>
        string.IsNullOrEmpty(s) ? s : char.ToUpper(s[0]) + s[1..];

    // REQ-OPS-005: Init theme and Lucide icons after render
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await JS.InvokeVoidAsync("zenohr.initTheme");
                await JS.InvokeVoidAsync("zenohr.initLucide");
            }
            catch (JSDisconnectedException)
            {
                // Circuit disconnected — safe to ignore during prerender/disconnect.
            }
        }
    }
