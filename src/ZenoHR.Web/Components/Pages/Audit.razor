    // Filtering state — REQ-COMP-004
    private string _activeFilter = "All";
    private string _searchQuery = "";
    private string _actorFilter = "";

    private static readonly string[] _filterTypes = new[] { "All", "Payroll", "Employee", "Leave", "Auth", "Compliance", "Config", "Data" };

    private IEnumerable<AuditEvent> FilteredEvents
    {
        get
        {
            var result = _activeFilter == "All"
                ? _events.AsEnumerable()
                : _events.Where(e => e.EventType.Equals(_activeFilter, StringComparison.OrdinalIgnoreCase));

            if (!string.IsNullOrWhiteSpace(_actorFilter))
                result = result.Where(e => e.Actor.Equals(_actorFilter, StringComparison.OrdinalIgnoreCase));

            if (!string.IsNullOrWhiteSpace(_searchQuery))
                result = result.Where(e =>
                    e.EventName.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) ||
                    e.Actor.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) ||
                    e.Summary.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) ||
                    e.EntityId.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase));

            return result;
        }
    }

    // Chain integrity check — CTL-SEC-008
    private bool AllChainValid => _events.All(e => e.ChainValid);

