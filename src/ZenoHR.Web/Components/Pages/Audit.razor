@* REQ-COMP-004: Audit trail — tamper-evident hash-chained event log *@
@* CTL-SEC-008: SHA-256 hash-chained audit events with integrity verification *@
@* REQ-SEC-002: Director/HRManager see full tenant audit; SaasAdmin sees platform-level only *@
@page "/audit"
@attribute [Authorize(Roles = "Director,HRManager,SaasAdmin")]
@using Microsoft.AspNetCore.Authorization
@inject IJSRuntime JS

<PageTitle>Audit Trail — ZenoHR</PageTitle>

<style>
    /* ── Audit event types ────────────────────────────────────────── */
    .event-type-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: .72rem;
        font-weight: 600;
        white-space: nowrap;
    }

    .evt-payroll {
        background: #e8f0fb;
        color: #1d4777;
    }

    .evt-employee {
        background: #e8f7ef;
        color: #1a7a44;
    }

    .evt-leave {
        background: #fef3e2;
        color: #b86b00;
    }

    .evt-auth {
        background: #f3eafd;
        color: #7b2fbe;
    }

    .evt-compliance {
        background: #fdecea;
        color: #c0392b;
    }

    .evt-config {
        background: var(--surface-hover);
        color: var(--text-secondary);
    }

    .evt-data {
        background: #e0f7fa;
        color: #006064;
    }

    [data-theme="dark"] .evt-payroll {
        background: rgba(29, 71, 119, .3);
        color: #7fafd6;
    }

    [data-theme="dark"] .evt-employee {
        background: rgba(26, 122, 68, .25);
        color: #3ddc82;
    }

    [data-theme="dark"] .evt-leave {
        background: rgba(212, 137, 14, .2);
        color: #f0a83a;
    }

    [data-theme="dark"] .evt-auth {
        background: rgba(123, 47, 190, .25);
        color: #c084fc;
    }

    [data-theme="dark"] .evt-compliance {
        background: rgba(192, 57, 43, .25);
        color: #ff6b6b;
    }

    [data-theme="dark"] .evt-config {
        background: rgba(255, 255, 255, .08);
        color: var(--text-muted);
    }

    [data-theme="dark"] .evt-data {
        background: rgba(0, 96, 100, .3);
        color: #4dd0e1;
    }

    /* ── Hash chain ───────────────────────────────────────────────── */
    .hash-cell {
        font-family: var(--font-mono);
        font-size: .72rem;
        color: var(--text-muted);
        white-space: nowrap;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .hash-value {
        letter-spacing: .02em;
    }

    .copy-btn {
        background: none;
        border: none;
        cursor: pointer;
        color: var(--text-disabled);
        padding: 2px 4px;
        border-radius: 4px;
        line-height: 1;
        transition: color .15s;
        display: flex;
        align-items: center;
    }

    .copy-btn:hover {
        color: var(--brand-primary);
    }

    .chain-indicator {
        display: flex;
        align-items: center;
        gap: 4px;
        font-size: .7rem;
        font-weight: 600;
        justify-content: center;
    }

    .chain-ok {
        color: #27ae60;
    }

    .chain-broken {
        color: #e74c3c;
    }

    /* ── Filter panel ─────────────────────────────────────────────── */
    .filter-row {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        align-items: center;
        padding: 14px 20px;
        border-bottom: 1px solid var(--border-subtle);
    }

    .filter-select {
        padding: 6px 12px;
        border-radius: 8px;
        border: 1px solid var(--border-subtle);
        background: var(--surface);
        color: var(--text-primary);
        font-size: .82rem;
        font-family: var(--font-sans);
        cursor: pointer;
        outline: none;
    }

    .filter-select:focus {
        border-color: var(--brand-primary);
    }

    [data-theme="dark"] .filter-select {
        background: var(--surface-hover);
    }

    .search-input {
        flex: 1;
        min-width: 200px;
        padding: 7px 12px 7px 36px;
        border-radius: 8px;
        border: 1px solid var(--border-subtle);
        background: var(--surface);
        color: var(--text-primary);
        font-size: .82rem;
        font-family: var(--font-sans);
        outline: none;
    }

    .search-input:focus {
        border-color: var(--brand-primary);
    }

    [data-theme="dark"] .search-input {
        background: var(--surface-hover);
    }

    .search-wrap {
        position: relative;
        flex: 1;
        min-width: 200px;
    }

    .search-wrap .search-icon {
        position: absolute;
        left: 10px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--text-muted);
        pointer-events: none;
    }

    /* ── Integrity banner ─────────────────────────────────────────── */
    .integrity-banner {
        display: flex;
        flex-direction: column;
        gap: 0;
        padding: 12px 16px;
        border-radius: 10px;
        font-size: .82rem;
        margin-bottom: 16px;
    }

    .integrity-banner.ok {
        background: #e8f7ef;
        color: #1a7a44;
        border: 1px solid rgba(26, 122, 68, .2);
    }

    .integrity-banner.broken {
        background: #fdecea;
        color: #c0392b;
        border: 1px solid rgba(192, 57, 43, .2);
    }

    [data-theme="dark"] .integrity-banner.ok {
        background: rgba(26, 122, 68, .2);
        color: #3ddc82;
        border-color: rgba(26, 122, 68, .3);
    }

    [data-theme="dark"] .integrity-banner.broken {
        background: rgba(192, 57, 43, .2);
        color: #ff6b6b;
        border-color: rgba(192, 57, 43, .3);
    }

    .integrity-banner-top {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    .integrity-timestamp {
        margin-left: auto;
        font-size: .75rem;
        opacity: .8;
        white-space: nowrap;
    }

    /* ── Audit KPIs ───────────────────────────────────────────────── */
    .audit-kpis {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 14px;
        margin-bottom: 20px;
    }

    @@media (max-width: 900px) {
        .audit-kpis {
            grid-template-columns: 1fr 1fr;
        }
    }

    .audit-kpi {
        background: var(--surface);
        border: 1px solid var(--border-subtle);
        border-radius: 14px;
        padding: 14px 16px;
    }

    .audit-kpi-label {
        font-size: .72rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .05em;
        color: var(--text-muted);
        margin-bottom: 4px;
    }

    .audit-kpi-value {
        font-size: 1.4rem;
        font-weight: 800;
        font-family: var(--font-mono);
        color: var(--text-primary);
    }

    .audit-kpi-sub {
        font-size: .75rem;
        color: var(--text-secondary);
        margin-top: 2px;
    }

    /* ── Actor cell ───────────────────────────────────────────────── */
    .actor-cell {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .actor-name {
        font-size: .82rem;
        font-weight: 500;
    }

    .actor-role {
        font-size: .7rem;
        color: var(--text-muted);
    }

    /* ── Entity cell ──────────────────────────────────────────────── */
    .entity-label {
        font-size: .78rem;
        font-family: var(--font-mono);
        color: var(--text-secondary);
        background: var(--surface-hover);
        padding: 2px 7px;
        border-radius: 5px;
        display: inline-block;
    }

    /* Description cell */
    .desc-cell {
        font-size: .82rem;
        color: var(--text-primary);
        max-width: 260px;
    }

    .desc-cell .desc-sub {
        font-size: .72rem;
        color: var(--text-muted);
        margin-top: 2px;
    }

    .ts-text {
        font-family: var(--font-mono);
        font-size: .78rem;
        color: var(--text-secondary);
        white-space: nowrap;
    }

    /* Filter chips */
    .filter-chips {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
        padding: 12px 20px;
        border-bottom: 1px solid var(--border-subtle);
    }

    /* Expanded row detail */
    .audit-expand-row td {
        padding: 0 14px 14px 14px;
        background: var(--surface-hover);
    }

    .audit-expand-inner {
        background: var(--surface);
        border: 1px solid var(--border-subtle);
        border-radius: 8px;
        padding: 12px 14px;
        font-family: var(--font-mono);
        font-size: .75rem;
        color: var(--text-secondary);
        white-space: pre-wrap;
        word-break: break-all;
    }

    /* ── Mobile responsive ───────────────────────────── */
    @@media (max-width: 768px) {
        .audit-kpis {
            grid-template-columns: 1fr 1fr;
        }
    }

    @@media (max-width: 640px) {
        .filter-row {
            flex-direction: column;
            gap: 8px;
        }

        .search-wrap {
            width: 100%;
        }

        .filter-select {
            width: 100%;
        }

        .integrity-banner-top {
            flex-direction: column;
            align-items: flex-start;
            gap: 8px;
        }

        .integrity-timestamp {
            margin-left: 0;
        }
    }
</style>

<div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:24px;flex-wrap:wrap;gap:12px;">
    <div>
        <h1 style="font-size:1.5rem;font-weight:800;color:var(--text-primary);letter-spacing:-.5px;margin:0 0 4px;">Audit Trail</h1>
        <p style="font-size:.875rem;color:var(--text-secondary);margin:0;">Tamper-evident hash-chained event log</p>
    </div>
    <div style="display:flex;gap:8px;align-items:center;">
        <button class="btn btn-outline" style="font-size:.85rem;" aria-label="Export audit trail">
            <i data-lucide="download" style="width:15px;height:15px;" aria-hidden="true"></i> Export
        </button>
    </div>
</div>

<!-- Chain integrity banner — CTL-SEC-008, REQ-COMP-004 -->
<div class="integrity-banner @(AllChainValid ? "ok" : "broken")">
    <div class="integrity-banner-top">
        @if (AllChainValid)
        {
            <i data-lucide="shield-check" style="width:17px;height:17px;flex-shrink:0;"></i>
            <span><strong>Tamper-proof log verified</strong> — All @_events.Count records are authentic and unmodified.</span>
        }
        else
        {
            <i data-lucide="shield-x" style="width:17px;height:17px;flex-shrink:0;"></i>
            <span><strong>Chain integrity breach detected</strong> — One or more records may have been tampered with.</span>
        }
        <span class="integrity-timestamp">Last checked: @DateTime.Now.ToString("d MMM yyyy HH:mm") SAST</span>
    </div>
</div>

<!-- KPI row — REQ-COMP-004 -->
<div class="audit-kpis">
    <div class="audit-kpi">
        <div class="audit-kpi-label">Total Events</div>
        <div class="audit-kpi-value">@_events.Count</div>
        <div class="audit-kpi-sub">since 1 Jan 2026</div>
    </div>
    <div class="audit-kpi">
        <div class="audit-kpi-label">Today</div>
        <div class="audit-kpi-value">@_events.Count(e => e.Timestamp.Date == DateTime.Today)</div>
        <div class="audit-kpi-sub">events logged</div>
    </div>
    <div class="audit-kpi">
        <div class="audit-kpi-label">Chain Status</div>
        <div class="audit-kpi-value" style="color:@(AllChainValid ? "#27ae60" : "#e74c3c");">
            @(AllChainValid ? "✓ Valid" : "⚠ Broken")
        </div>
        <div class="audit-kpi-sub">@_events.Count(e => e.ChainValid) of @_events.Count verified</div>
    </div>
    <div class="audit-kpi">
        <div class="audit-kpi-label">Unique Actors</div>
        <div class="audit-kpi-value">@_events.Select(e => e.Actor).Distinct().Count()</div>
        <div class="audit-kpi-sub">users + system</div>
    </div>
</div>

<!-- Event log table — REQ-COMP-004, CTL-SEC-008 -->
<div class="card" style="padding:0;overflow:hidden;">

    <!-- Filter chips -->
    <div class="filter-chips">
        @foreach (var filterType in _filterTypes)
        {
            <button class="chip @(_activeFilter == filterType ? "chip-active" : "")"
                    @onclick="() => _activeFilter = filterType">
                @filterType
            </button>
        }
    </div>

    <!-- Search and filter row -->
    <div class="filter-row">
        <div class="search-wrap">
            <i data-lucide="search" class="search-icon" style="width:14px;height:14px;"></i>
            <input class="search-input" type="text" placeholder="Search events, actors, entities…"
                   @bind="_searchQuery" @bind:event="oninput" />
        </div>
        <select class="filter-select" @bind="_actorFilter">
            <option value="">All Actors</option>
            @foreach (var actor in _events.Select(e => e.Actor).Distinct().OrderBy(a => a))
            {
                <option value="@actor">@actor</option>
            }
        </select>
        <span style="font-size:.78rem;color:var(--text-muted);white-space:nowrap;">@FilteredEvents.Count() events</span>
    </div>

    <!-- Table -->
    <div style="overflow-x:auto;">
        <table class="audit-table" style="width:100%;border-collapse:collapse;">
            <thead>
                <tr style="background:var(--surface-hover);border-bottom:1px solid var(--border-subtle);">
                    <th style="padding:10px 14px;font-size:.72rem;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:.05em;text-align:left;white-space:nowrap;">#</th>
                    <th style="padding:10px 14px;font-size:.72rem;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:.05em;text-align:left;white-space:nowrap;">Timestamp</th>
                    <th style="padding:10px 14px;font-size:.72rem;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:.05em;text-align:left;">Actor</th>
                    <th style="padding:10px 14px;font-size:.72rem;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:.05em;text-align:left;">Event Type</th>
                    <th style="padding:10px 14px;font-size:.72rem;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:.05em;text-align:left;">Entity</th>
                    <th style="padding:10px 14px;font-size:.72rem;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:.05em;text-align:left;">Description</th>
                    <th style="padding:10px 14px;font-size:.72rem;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:.05em;text-align:left;white-space:nowrap;">Record Fingerprint</th>
                    <th style="padding:10px 14px;font-size:.72rem;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:.05em;text-align:center;">Integrity</th>
                </tr>
            </thead>
            <tbody>
                @if (!FilteredEvents.Any())
                {
                    <tr>
                        <td colspan="8" style="text-align:center;padding:var(--space-8);color:var(--text-muted);">
                            <div style="display:flex;flex-direction:column;align-items:center;gap:var(--space-3);">
                                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none"
                                    stroke="currentColor" stroke-width="1.5" style="opacity:0.4;" aria-hidden="true">
                                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                                </svg>
                                <span style="font-size:14px;">No audit events found</span>
                                <span style="font-size:12px;opacity:0.7;">Try adjusting your filters or search criteria</span>
                            </div>
                        </td>
                    </tr>
                }
                @{ int rowNum = FilteredEvents.Count(); }
                @foreach (var evt in FilteredEvents)
                {
                    var currentRow = rowNum--;
                    var isExpanded = _expandedId == evt.Id;
                    <tr style="border-bottom:1px solid var(--border-subtle);cursor:pointer;" @onclick="() => ToggleExpand(evt.Id)">
                        <td style="padding:12px 14px;">
                            <span class="ts-text">@currentRow</span>
                        </td>
                        <td style="padding:12px 14px;">
                            <div class="ts-text">@evt.Timestamp.ToString("yyyy-MM-dd")</div>
                            <div class="ts-text" style="opacity:.7;">@evt.Timestamp.ToString("HH:mm:ss") SAST</div>
                        </td>
                        <td style="padding:12px 14px;">
                            <div class="actor-cell">
                                @{
                                    var initials = GetActorInitials(evt.Actor);
                                    var avatarClass = GetActorAvatarClass(evt.Actor);
                                }
                                <div class="avatar avatar-sm @avatarClass">@initials</div>
                                <div>
                                    <div class="actor-name">@GetActorDisplayName(evt.Actor)</div>
                                    <div class="actor-role">@GetActorRole(evt.Actor)</div>
                                </div>
                            </div>
                        </td>
                        <td style="padding:12px 14px;">
                            <span class="event-type-badge @EventTypeCss(evt.EventType)">
                                <i data-lucide="@EventTypeIcon(evt.EventType)" style="width:11px;height:11px;"></i>
                                @CapitalizeFirst(evt.EventType)
                            </span>
                        </td>
                        <td style="padding:12px 14px;">
                            <span class="entity-label">@evt.EntityType/@evt.EntityId</span>
                        </td>
                        <td style="padding:12px 14px;">
                            <div class="desc-cell">
                                @evt.EventName
                                <div class="desc-sub">@evt.Summary</div>
                            </div>
                        </td>
                        <td style="padding:12px 14px;">
                            <div class="hash-cell">
                                <code title="@evt.Hash" style="font-family:var(--font-mono);font-size:.75rem;cursor:help;">
                                    @ShortHash(evt.Hash)
                                </code>
                                @if (evt.ChainValid)
                                {
                                    <i data-lucide="link" style="width:12px;height:12px;color:var(--success);margin-left:4px;"></i>
                                }
                                else
                                {
                                    <i data-lucide="link-2-off" style="width:12px;height:12px;color:var(--error);margin-left:4px;"></i>
                                }
                            </div>
                        </td>
                        <td style="padding:12px 14px;text-align:center;">
                            @if (evt.ChainValid)
                            {
                                <div class="chain-indicator chain-ok">
                                    <i data-lucide="link" style="width:12px;height:12px;"></i>
                                </div>
                            }
                            else
                            {
                                <div class="chain-indicator chain-broken">
                                    <i data-lucide="link-2-off" style="width:12px;height:12px;"></i>
                                </div>
                            }
                        </td>
                    </tr>
                    @if (isExpanded)
                    {
                        <tr class="audit-expand-row" style="border-bottom:1px solid var(--border-subtle);">
                            <td colspan="8">
                                <div class="audit-expand-inner">
                                    <strong style="font-family:var(--font-sans);font-size:.75rem;color:var(--text-primary);">Event Details</strong><br/>
                                    ID:              @evt.Id
                                    Timestamp:       @evt.Timestamp.ToString("o")
                                    Actor:           @evt.Actor
                                    Event:           @evt.EventName (@evt.EventType)
                                    Entity:          @evt.EntityType / @evt.EntityId
                                    Summary:         @evt.Summary
                                    Hash:            @evt.Hash
                                    Previous Hash:   @evt.PreviousHash
                                    Chain Valid:     @evt.ChainValid
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

