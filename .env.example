# ZenoHR Environment Variables
# Copy this file to .env and fill in actual values. Never commit .env to source control.

# --- Firebase / Firestore ---
FIREBASE_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=
FIRESTORE_EMULATOR_HOST=localhost:8080

# --- ASP.NET Core ---
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5000

# --- Azure Key Vault (production secrets) ---
AZURE_KEYVAULT_URI=

# --- Azure Container Apps (deployment) ---
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
AZURE_CONTAINER_APP_NAME=

# --- Application Insights / OpenTelemetry ---
APPLICATIONINSIGHTS_CONNECTION_STRING=

# --- SARS e-Filing Integration ---
SARS_EFILING_API_URL=
SARS_EFILING_CLIENT_ID=
SARS_EFILING_CLIENT_SECRET=
